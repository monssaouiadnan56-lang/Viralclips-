# ──────────────────────────────────────────────────────────────────────────────
# Supabase (existente)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI (existente)
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────────────────
# Cloudflare — NUEVO (Fase 1: R2 + Worker)
# ──────────────────────────────────────────────────────────────────────────────

# Cloudflare Account ID
# Dónde encontrarlo: Dashboard → lado derecho → "Account ID"
CLOUDFLARE_ACCOUNT_ID=071bab0d58e46f22c65fcff4ce93b8ca

# R2 Bucket
# Nombre exacto del bucket creado en R2
CLOUDFLARE_R2_BUCKET_NAME=viralclips-videos

# R2 API Token — Access Key y Secret
# Dónde generarlo: Dashboard → R2 → "Manage R2 API tokens" → Create API token
# Permisos necesarios: Object Read & Write en el bucket "viralclips-videos"
CLOUDFLARE_R2_ACCESS_KEY_ID=3d72d12250222bedbaadd12f711d47a8
CLOUDFLARE_R2_SECRET_ACCESS_KEY=227aada2eae469cd31655450af2466abb3484de7c2f7260c309b9a2f9e8ff742

# URL pública del Worker desplegado (prefijo NEXT_PUBLIC_ para que el browser lo vea)
# Después de `wrangler deploy` te da: https://viralclips-processor.<subdominio>.workers.dev
# En desarrollo local usa: http://localhost:8787
NEXT_PUBLIC_CLOUDFLARE_WORKER_URL=https://viralclips-processor.<subdominio>.workers.dev
CLOUDFLARE_WORKER_URL=https://viralclips-processor.<subdominio>.workers.dev
