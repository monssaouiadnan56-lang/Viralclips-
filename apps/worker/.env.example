# Server
PORT=3001

# Shared secret — must match WORKER_SECRET in the web app
WORKER_SECRET=change-me-to-a-random-secret

# Supabase (service role key bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_BUCKET_NAME=viralclips-videos
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key

# yt-dlp binary path (leave empty to use system PATH — default on Railway)
# YTDLP_PATH=/usr/bin/yt-dlp
